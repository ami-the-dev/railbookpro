# IRCTC API Key (get from https://irctc.rajivdubey.tech)
IRCTC_API_KEY=

# Database
DATABASE_URL="postgresql://railbook:railbook@localhost:5432/railbookpro"

# Redis
REDIS_URL="redis://localhost:6379"

# WireMock (local dev mock for IRCTC booking APIs)
WIREMOCK_URL="http://localhost:8080"

# Next Auth
AUTH_SECRET="your-secret-key-change-in-production"
AUTH_URL="http://localhost:3000"

# Email (Gmail SMTP - use an App Password from Google)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_SECURE="false"
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-gmail-app-password"

# Public app URL (used in email links)
NEXT_PUBLIC_APP_URL="http://localhost:3000"
