{
  "priority": 1,
  "request": {
    "method": "POST",
    "url": "/api/book",
    "bodyPatterns": [
      {
        "matchesJsonPath": "$.train_number"
      }
    ]
  },
  "response": {
    "status": 200,
    "jsonBody": {
      "status": true,
      "pnr": "{{randomValue length=10 type='NUMERIC'}}",
      "train_number": "{{jsonPath request.body '$.train_number'}}",
      "train_name": "{{jsonPath request.body '$.train_name'}}",
      "from": "{{jsonPath request.body '$.from_station'}}",
      "to": "{{jsonPath request.body '$.to_station'}}",
      "travel_date": "{{jsonPath request.body '$.date'}}",
      "class": "{{jsonPath request.body '$.class'}}",
      "quota": "{{jsonPath request.body '$.tatkal'}}",
      "booking_status": "CONFIRMED",
      "seat": "S4/34-LB",
      "total_fare": "{{jsonPath request.body '$.passengers.length'}}",
      "message": "Booking confirmed successfully"
    },
    "headers": {
      "Content-Type": "application/json"
    },
    "transformers": ["response-template"]
  }
}
